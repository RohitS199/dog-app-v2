{
  "expo": {
    "name": "PupLog",
    "slug": "puplog",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "puplog",
    "splash": {
      "image": "./assets/logo-transparent.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6EFDD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puplog.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.puplog.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "PupLog needs access to your photos to set a profile picture."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bf10dede-6741-4591-bcf2-fd3df2cef358"
      }
    },
    "owner": "ras199"
  }
}
